# venv + direnv
.venv/
.direnv/

# IDE
.idea/
# clangd/CLion compilation database — regenerated by `bak compdb`; holds
# absolute, machine-local paths (source tree + probed compiler), never committed
/compile_commands.json

# build scratch (regenerated by `bak build`: FreeDOS image, logs, objs, EXE)
work/

# python
__pycache__/
*.pyc

# vendored DOS toolchain: fetched by the flake (hash-pinned), not committed
/toolchain/
/toolchain.tar.gz

# clangd index cache
.cache/

# Claude Code local state (settings.json IS committed: enables the clangd-lsp plugin)
.claude/settings.local.json
.claude/worktrees/

# local-only internal notes / working docs — not published
/internal/
