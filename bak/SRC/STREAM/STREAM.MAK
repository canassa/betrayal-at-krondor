	$(AS) $(ASFLAGS) SRC\STREAM\BUFLOAD\D_3160_5.ASM,OUT\D_3160_5.OBJ
OUT\D_3160_6.OBJ : SRC\STREAM\BUFLOAD\D_3160_6.ASM
	$(AS) $(ASFLAGS) SRC\STREAM\BUFLOAD\D_3160_6.ASM,OUT\D_3160_6.OBJ
OUT\D_3160_7.OBJ : SRC\STREAM\BUFLOAD\D_3160_7.ASM
	$(AS) $(ASFLAGS) SRC\STREAM\BUFLOAD\D_3160_7.ASM,OUT\D_3160_7.OBJ
OUT\D_3160_8.OBJ : SRC\STREAM\BUFLOAD\D_3160_8.ASM
	$(AS) $(ASFLAGS) SRC\STREAM\BUFLOAD\D_3160_8.ASM,OUT\D_3160_8.OBJ
OUT\D_3160_9.OBJ : SRC\STREAM\BUFLOAD\D_3160_9.ASM
	$(AS) $(ASFLAGS) SRC\STREAM\BUFLOAD\D_3160_9.ASM,OUT\D_3160_9.OBJ
OUT\FONTLOAD.OBJ : SRC\STREAM\RESLOAD\FONTLOAD.C
	$(X_GO) $(INC) -c -zCS180c_TEXT -nOUT SRC\STREAM\RESLOAD\FONTLOAD.C
OUT\IFFREAD.OBJ : SRC\STREAM\RESLOAD\IFFREAD.C
	$(X_GO) $(INC) -c -zCS180c_TEXT -nOUT SRC\STREAM\RESLOAD\IFFREAD.C
OUT\IMGLOAD.OBJ : SRC\STREAM\RESLOAD\IMGLOAD.C
	$(X_GO) $(INC) -c -zCS180c_TEXT -nOUT SRC\STREAM\RESLOAD\IMGLOAD.C
OUT\LOADCHNK.OBJ : SRC\STREAM\BUFLOAD\LOADCHNK.C
	$(C_O2) $(INC) -c -zCS32b6_TEXT -nOUT SRC\STREAM\BUFLOAD\LOADCHNK.C
OUT\LZHINIT.OBJ : SRC\STREAM\CODEC\LZHINIT.C
	$(D_STD) $(INC) -c -zCS180c_TEXT -nOUT SRC\STREAM\CODEC\LZHINIT.C
OUT\LZHOPEN.OBJ : SRC\STREAM\CODEC\LZHOPEN.C
