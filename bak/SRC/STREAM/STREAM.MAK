# STREAM module -- object list + rules (byte-verified recipes; hand-curate).
STREAM_OBJS = OUT\BLITRLE.OBJ OUT\CHUNKRD.OBJ OUT\CODEC.OBJ OUT\D_3160_0.OBJ OUT\D_3160_1.OBJ OUT\D_3160_2.OBJ OUT\D_3160_3.OBJ OUT\D_3160_4.OBJ OUT\D_3160_5.OBJ OUT\D_3160_6.OBJ OUT\D_3160_7.OBJ OUT\D_3160_8.OBJ OUT\D_3160_9.OBJ OUT\FONTLOAD.OBJ OUT\IFFREAD.OBJ OUT\IMGLOAD.OBJ OUT\LOADCHNK.OBJ OUT\LZHINIT.OBJ OUT\LZHOPEN.OBJ OUT\LZHUF.OBJ OUT\LZW.OBJ OUT\LZWDEC.OBJ OUT\RELBUF.OBJ OUT\RLEWRITE.OBJ OUT\STREAM.OBJ OUT\STRMLOAD.OBJ

OUT\BLITRLE.OBJ : SRC\STREAM\CODEC\BLITRLE.ASM
	$(AS) $(ASFLAGS) SRC\STREAM\CODEC\BLITRLE.ASM,OUT\BLITRLE.OBJ
OUT\CHUNKRD.OBJ : SRC\STREAM\BUFLOAD\CHUNKRD.C
	$(X_GO) $(INC) -c -zCS3160_TEXT -nOUT SRC\STREAM\BUFLOAD\CHUNKRD.C
OUT\CODEC.OBJ : SRC\STREAM\CODEC\CODEC.C
	$(D_STD) $(INC) -c -zCS180c_TEXT -nOUT SRC\STREAM\CODEC\CODEC.C
OUT\D_3160_0.OBJ : SRC\STREAM\BUFLOAD\D_3160_0.ASM
	$(AS) $(ASFLAGS) SRC\STREAM\BUFLOAD\D_3160_0.ASM,OUT\D_3160_0.OBJ
