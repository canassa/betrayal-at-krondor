# DIALOG module -- object list + rules (byte-verified recipes; hand-curate).
DIALOG_OBJS = OUT\ASKABOUT.OBJ OUT\DIALOG.OBJ OUT\EVTCOND.OBJ

OUT\ASKABOUT.OBJ : SRC\DIALOG\ASKABOUT.C
	$(C_3O1Y) $(INC) -c -zCS4a91_TEXT -nOUT SRC\DIALOG\ASKABOUT.C
OUT\DIALOG.OBJ : SRC\DIALOG\DIALOG.C
	$(C_3O1Y) $(INC) -c -zCS4800_TEXT -nOUT SRC\DIALOG\DIALOG.C
OUT\EVTCOND.OBJ : SRC\DIALOG\EVTCOND.C
	$(C_3O1Y) $(INC) -c -zCS4074_TEXT -nOUT SRC\DIALOG\EVTCOND.C
