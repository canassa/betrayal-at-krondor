TCGOBJ = OUT\CHUNKRD.OBJ OUT\CIRCLE.OBJ OUT\CODEC.OBJ OUT\FARTHUNK.OBJ OUT\FONTLOAD.OBJ OUT\IFFREAD.OBJ OUT\IMGLOAD.OBJ \
OUT\LZHINIT.OBJ OUT\LZHOPEN.OBJ OUT\LZW.OBJ OUT\SHAPETBL.OBJ OUT\PALDRV.OBJ OUT\PANICF.OBJ \
OUT\POLYFILL.OBJ OUT\RLEWRITE.OBJ OUT\STRBLIT.OBJ OUT\STREAM.OBJ OUT\VIDDRV.OBJ OUT\SHAPEBLD.OBJ

ALLOBJ = $(KVMOBJ) $(TCGOBJ)

kvmobjs : $(KVMOBJ)
tcgobjs : $(TCGOBJ)
objs    : $(ALLOBJ)
all     : krondor.exe ovls
link    : krondor.exe

krondor.exe : KRONDOR.RSP
	tlink /m @KRONDOR.RSP

# ----------------------------------------------------------------------------
# The two loadable driver archives. `ovls` builds PACKOVL (TOOLS.MAK), assembles
# every driver chunk (DRIVERS.MAK: the 8 video + 11 sound .EXEs), then packs
# each archive from its pack spec. All KVM-safe (bcc/tasm/tlink + PACKOVL.EXE),
# so `all` builds them in the same single KVM boot that links KRONDOR.EXE.
# ----------------------------------------------------------------------------
ovls : OUT\VMCODE.OVL OUT\SX.OVL

OUT\VMCODE.OVL : OUT\PACKOVL.EXE $(VMEXE) SRC\DRIVERS\VMCODE.PAK
	OUT\PACKOVL SRC\DRIVERS\VMCODE.PAK OUT\VMCODE.OVL

OUT\SX.OVL : OUT\PACKOVL.EXE $(SXEXE) \
		SRC\DRIVERS\SX\001.BIN SRC\DRIVERS\SX\003.BIN SRC\DRIVERS\SX\004.BIN SRC\DRIVERS\SX.PAK
	OUT\PACKOVL SRC\DRIVERS\SX.PAK OUT\SX.OVL

OUT\GFXCTX.OBJ : SRC\GEN\GFXCTX.ASM
	$(AS) $(ASFLAGS) SRC\GEN\GFXCTX.ASM,OUT\GFXCTX.OBJ
OUT\RNDVTBL.OBJ : SRC\GEN\RNDVTBL.ASM
	$(AS) $(ASFLAGS) SRC\GEN\RNDVTBL.ASM,OUT\RNDVTBL.OBJ
OUT\VIDVTBL.OBJ : SRC\GEN\VIDVTBL.ASM
	$(AS) $(ASFLAGS) SRC\GEN\VIDVTBL.ASM,OUT\VIDVTBL.OBJ

# ============================================================================
# V1.02 CD build. The 1.02 CD KRONDOR.EXE (456048 B) is a surgical patch of the
# 1.00 EXE: exactly 30 C TUs recompiled with -DV102CD (source-guarded #ifdef
# V102CD deltas) plus ONE all-new resident TASM module (CDAUDIO, the MSCDEX
# CD-audio driver at seg 168a). Everything else -- including the whole TCG-island
# set -- is byte-identical to 1.00 and reused from OUT\ unchanged. The 102 objects
# land in a separate OUT102\ namespace so the 1.00 objects in OUT\ are untouched.
#
# Each 102 rule mirrors its 1.00 counterpart (found in the module .MAK) exactly --
# same flag band, same -zC<class>, same include flags -- with -DV102CD appended
# (right after $(INC)) and the output redirected to OUT102\. The .MAK files are
# shared with the 1.00 build; the whole V102 delta lives here in one place.
#
# The link (link102) uses KRN102.RSP: the SAME module order as KRONDOR.RSP, with
# the 30 TUs repointed to OUT102\, CDAUDIO.OBJ spliced before DISTDIR.OBJ, and the
# output redirected to OUT102\KRONDOR.EXE (the OVRINFO self-name embeds the file
# NAME, so the output MUST stay KRONDOR.EXE; the OVRINFO date is pinned by the
# launcher's 1994-03-21 clock, not by MAKE). VMCODE.OVL/SX.OVL are 1.00-identical
# in 1.02 -- no 102 variants, so `ovls` is not part of the 102 flow.
# ----------------------------------------------------------------------------
V102OBJ = OUT102\IO.OBJ OUT102\AUDIO.OBJ OUT102\GMAIN.OBJ OUT102\WORLDHIT.OBJ OUT102\BOOT.OBJ \
OUT102\SAVEGAME.OBJ OUT102\GSTATE.OBJ OUT102\STAT.OBJ OUT102\CFGPARSE.OBJ OUT102\PROXSCAN.OBJ \
OUT102\WORLDFRM.OBJ OUT102\DIALOG.OBJ OUT102\ASKABOUT.OBJ OUT102\TOWNSCN.OBJ OUT102\ACTSPAWN.OBJ \
OUT102\CACTOR.OBJ OUT102\COMBAT.OBJ OUT102\CBENC.OBJ OUT102\CBTAI.OBJ OUT102\CSPELL.OBJ \
OUT102\CBTAIACT.OBJ OUT102\CBSTAT.OBJ OUT102\MAP.OBJ OUT102\MAINMENU.OBJ OUT102\ZONE.OBJ \
OUT102\HOTSPOT.OBJ OUT102\WCURSOR.OBJ OUT102\WORLDRND.OBJ OUT102\SCREEN.OBJ OUT102\WORLDFX.OBJ \
OUT102\INVENTOR.OBJ OUT102\CDAUDIO.OBJ

kvmobjs102 : $(V102OBJ)
link102    : OUT102\KRONDOR.EXE

OUT102\KRONDOR.EXE : KRN102.RSP
	tlink /m @KRN102.RSP

OUT102\INVENTOR.OBJ : SRC\SCREENS\INVENTOR.C
	$(C_3O1Y) $(INC) -DV102CD -c -zCS5684_TEXT -nOUT102 SRC\SCREENS\INVENTOR.C

# --- the all-new 1.02-only resident CD-audio driver (TASM, seg 168a) ---
OUT102\CDAUDIO.OBJ : SRC\AUDIO\CDAUDIO.ASM
	$(AS) $(ASFLAGS) SRC\AUDIO\CDAUDIO.ASM,OUT102\CDAUDIO.OBJ

# --- the 30 -DV102CD C recompiles (band/class/includes mirror the module .MAK) ---
OUT102\IO.OBJ : SRC\IO\IO.C
	$(C_3NY) $(INC) -DV102CD -c -zC_TEXT -nOUT102 SRC\IO\IO.C
OUT102\AUDIO.OBJ : SRC\AUDIO\ENGINE\AUDIO.C
	$(C_3O1Y) $(INC) -DV102CD -c -zCS14e8_TEXT -nOUT102 SRC\AUDIO\ENGINE\AUDIO.C
OUT102\GMAIN.OBJ : SRC\GAME\GMAIN.C
	$(C_3O1Y) $(INC) -DV102CD -c -zCS205a_TEXT -nOUT102 SRC\GAME\GMAIN.C
