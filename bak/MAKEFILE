# MAKEFILE -- top-level 1993-authentic Borland MAKE build for KRONDOR.EXE.
# Run inside the DOS VM from the bak\ root. Header deps come from each .OBJ
# (BCC autodependency, on by default).
.autodepend

!include RECIPES.MAK

# vtable/gfxctx storage modules (assembled resident, linked first)
GEN_OBJS = OUT\GFXCTX.OBJ OUT\RNDVTBL.OBJ OUT\VIDVTBL.OBJ

# per-module object lists + rules
!include SRC\AUDIO\AUDIO.MAK
!include SRC\CHAR\CHAR.MAK
!include SRC\COMBAT\COMBAT.MAK
!include SRC\DIALOG\DIALOG.MAK
!include SRC\GAME\GAME.MAK
!include SRC\GFX\GFX.MAK
!include SRC\INPUT\INPUT.MAK
!include SRC\IO\IO.MAK
!include SRC\R3D\R3D.MAK
!include SRC\SCREENS\SCREENS.MAK
!include SRC\SCRIPT\SCRIPT.MAK
!include SRC\STREAM\STREAM.MAK
!include SRC\SYS\SYS.MAK
!include SRC\UI\UI.MAK
!include SRC\WORLD\WORLD.MAK

# driver-chunk build rules (VMCODE/SX .EXE inputs) + the PACKOVL tool that
# packs them into the two .OVL archives ($(VMEXE)/$(SXEXE) come from DRIVERS.MAK)
!include SRC\DRIVERS\DRIVERS.MAK
!include TOOLS\TOOLS.MAK

# ----------------------------------------------------------------------------
# Backend split: a single MAKE run executes in ONE qemu accel, but bc31 C + TASM
# need KVM while bc2/bc30 C need TCG (protected-mode/DPMI walls, empirically
# verified). So the launcher runs `make kvmobjs` under KVM and `make tcgobjs`
# under TCG, then `make link`. `make objs` builds everything (single-accel
# smoke only). GEN + all asm are KVM.
# ----------------------------------------------------------------------------
