TCGOBJ = OUT\CHUNKRD.OBJ OUT\CIRCLE.OBJ OUT\CODEC.OBJ OUT\FARTHUNK.OBJ OUT\FONTLOAD.OBJ OUT\IFFREAD.OBJ OUT\IMGLOAD.OBJ \
OUT\LZHINIT.OBJ OUT\LZHOPEN.OBJ OUT\LZW.OBJ OUT\SHAPETBL.OBJ OUT\PALDRV.OBJ OUT\PANICF.OBJ \
OUT\POLYFILL.OBJ OUT\RLEWRITE.OBJ OUT\STRBLIT.OBJ OUT\STREAM.OBJ OUT\VIDDRV.OBJ OUT\SHAPEBLD.OBJ

ALLOBJ = $(KVMOBJ) $(TCGOBJ)

kvmobjs : $(KVMOBJ)
tcgobjs : $(TCGOBJ)
objs    : $(ALLOBJ)
all     : krondor.exe ovls
link    : krondor.exe

krondor.exe : KRONDOR.RSP
	tlink /m @KRONDOR.RSP

# ----------------------------------------------------------------------------
# The two loadable driver archives. `ovls` builds PACKOVL (TOOLS.MAK), assembles
# every driver chunk (DRIVERS.MAK: the 8 video + 11 sound .EXEs), then packs
# each archive from its pack spec. All KVM-safe (bcc/tasm/tlink + PACKOVL.EXE),
# so `all` builds them in the same single KVM boot that links KRONDOR.EXE.
# ----------------------------------------------------------------------------
ovls : OUT\VMCODE.OVL OUT\SX.OVL

OUT\VMCODE.OVL : OUT\PACKOVL.EXE $(VMEXE) SRC\DRIVERS\VMCODE.PAK
	OUT\PACKOVL SRC\DRIVERS\VMCODE.PAK OUT\VMCODE.OVL

OUT\SX.OVL : OUT\PACKOVL.EXE $(SXEXE) \
		SRC\DRIVERS\SX\001.BIN SRC\DRIVERS\SX\003.BIN SRC\DRIVERS\SX\004.BIN SRC\DRIVERS\SX.PAK
	OUT\PACKOVL SRC\DRIVERS\SX.PAK OUT\SX.OVL

OUT\GFXCTX.OBJ : SRC\GEN\GFXCTX.ASM
	$(AS) $(ASFLAGS) SRC\GEN\GFXCTX.ASM,OUT\GFXCTX.OBJ
OUT\RNDVTBL.OBJ : SRC\GEN\RNDVTBL.ASM
	$(AS) $(ASFLAGS) SRC\GEN\RNDVTBL.ASM,OUT\RNDVTBL.OBJ
OUT\VIDVTBL.OBJ : SRC\GEN\VIDVTBL.ASM
	$(AS) $(ASFLAGS) SRC\GEN\VIDVTBL.ASM,OUT\VIDVTBL.OBJ
